{
  "name": "@my-easy-claw/shared",
  "version": "0.1.0",
  "private": true,
  "description": "Shared types and constants for My-Easy-Claw",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "devDependencies": {
    "rimraf": "^6.0.0",
    "typescript": "^5.7.0"
  }
}
