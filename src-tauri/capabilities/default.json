{
  "$schema": "https://raw.githubusercontent.com/nicoverbruggen/tauri-v2-permission-schema/main/schema.json",
  "identifier": "default",
  "description": "Default capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:allow-execute",
    "shell:allow-open",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "sidecar",
          "sidecar": true,
          "args": true
        }
      ]
    }
  ]
}
